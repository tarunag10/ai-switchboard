{
  "name": "mac-ai-switchboard",
  "version": "0.0.0",
  "description": "Local-first Mac switchboard for AI coding-agent routing, token savings, and repo context packs.",
  "author": "Tarun Agarwal",
  "private": false,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "app:run": "./script/build_and_run.sh",
    "build": "tsc && vite build",
    "build:mac:dmg": "./scripts/build-macos-dmg.sh",
    "build:mac:local-install": "./scripts/build-install-local-dmg.sh",
    "preview": "vite preview",
    "tauri": "tauri",
    "test": "vitest run",
    "test:frontend": "vitest run",
    "test:coverage": "vitest run --coverage.enabled --coverage.provider=v8",
    "test:desktop": "cargo test --manifest-path src-tauri/Cargo.toml -- --test-threads=1",
    "fmt:desktop": "cargo fmt --manifest-path src-tauri/Cargo.toml --check",
    "test:all": "npm run test:frontend && npm run test:desktop",
    "release:check": "./scripts/verify-release.sh",
    "release:env": "node scripts/check-release-env.mjs",
    "release:env:json": "node scripts/check-release-env.mjs --json",
    "release:env:selftest": "node scripts/check-release-env-selftest.mjs",
    "release:report": "node scripts/release-readiness-report.mjs",
    "release:report:check": "node scripts/check-release-report-schema.mjs",
    "savings:benchmark": "node scripts/measured-savings-benchmark.mjs",
    "release:ready": "node scripts/check-release-readiness.mjs",
    "release:ready:strict": "node scripts/check-release-readiness.mjs --strict",
    "evidence:local": "node scripts/run-local-evidence.mjs",
    "smoke:preflight": "node scripts/smoke-preflight.mjs",
    "smoke:installed": "node scripts/installed-smoke-summary.mjs",
    "smoke:installed:local": "node scripts/local-installed-smoke-summary.mjs",
    "smoke:mode-relaunch:local": "node scripts/local-mode-relaunch-smoke.mjs",
    "smoke:rollback:local": "node scripts/local-rollback-validation-summary.mjs",
    "smoke:doctor-repair:local": "node scripts/local-doctor-repair-validation-summary.mjs",
    "smoke:uninstall:local": "node scripts/local-uninstall-validation-summary.mjs",
    "smoke:repo-intelligence:local": "node scripts/local-repo-intelligence-validation-summary.mjs",
    "smoke:repo-memory-mcp:local": "node scripts/local-repo-memory-mcp-validation-summary.mjs",
    "smoke:local-only:local": "node scripts/local-only-network-validation-summary.mjs",
    "repo:intelligence": "node scripts/repo-intelligence.mjs",
    "check:repo-memory-mcp": "node scripts/check-repo-memory-mcp.mjs",
    "benchmarks": "node scripts/run-benchmarks.mjs",
    "check:connectors": "node scripts/check-planned-connectors.mjs && node scripts/check-connector-manifests.mjs",
    "check:branding": "node scripts/check-branding-assets.mjs",
    "check:colors": "./scripts/check-colors.sh",
    "check:local-artifacts": "./scripts/check-no-local-artifacts.sh",
    "check:local-build-privacy": "node scripts/check-local-build-privacy.mjs",
    "check:local-only-network": "node scripts/check-local-only-network.mjs",
    "check:governance": "node scripts/check-governance-docs.mjs",
    "check:deployment": "node scripts/check-deployment-readiness.mjs",
    "smoke:connectors:local": "node scripts/local-connector-readiness-summary.mjs",
    "savings:benchmark:check": "node scripts/check-measured-savings-benchmark.mjs"
  },
  "dependencies": {
    "@microsoft/clarity": "^1.0.2",
    "@phosphor-icons/react": "^2.1.10",
    "@sentry/react": "^10.47.0",
    "@tauri-apps/api": "^2.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^6.0.1",
    "@vitest/coverage-v8": "^4.1.2",
    "jsdom": "^29.0.2",
    "postcss": "^8.5.10",
    "typescript": "^5.6.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.2"
  }
}
