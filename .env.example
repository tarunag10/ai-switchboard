# Local-free public build defaults. Keep remote services disabled unless you are
# intentionally building an operator/fork distribution with hosted services.
HEADROOM_BUILD_FLAVOR="local-free"
VITE_HEADROOM_BUILD_FLAVOR="local-free"
HEADROOM_LOCAL_ONLY="1"
VITE_HEADROOM_LOCAL_ONLY="1"
HEADROOM_REMOTE_SERVICES="0"
VITE_HEADROOM_REMOTE_SERVICES="0"
VITE_HEADROOM_REMOTE_TELEMETRY="0"

# Optional: app updater configuration for signed release builds
HEADROOM_UPDATER_PUBLIC_KEY="REPLACE_WITH_TAURI_UPDATER_PUBLIC_KEY"
HEADROOM_UPDATER_ENDPOINTS='["https://github.com/your-org/headroom-desktop/releases/latest/download/latest.json"]'

# Optional: local signed macOS DMG builds
APPLE_SIGNING_IDENTITY="REPLACE_WITH_APPLE_SIGNING_IDENTITY"
TAURI_SIGNING_PRIVATE_KEY="/absolute/path/to/headroom-desktop.key"
TAURI_SIGNING_PRIVATE_KEY_PASSWORD="REPLACE_WITH_TAURI_KEY_PASSWORD"

# Optional: preferred notarization mode using App Store Connect API
APPLE_API_ISSUER="REPLACE_WITH_APP_STORE_CONNECT_ISSUER_ID"
APPLE_API_KEY="REPLACE_WITH_APP_STORE_CONNECT_KEY_ID"
APPLE_API_KEY_PATH="/absolute/path/to/AuthKey_XXXXXXXXXX.p8"

# Optional: alternative notarization mode using Apple ID
# APPLE_ID="REPLACE_WITH_APPLE_ID_EMAIL"
# APPLE_PASSWORD="REPLACE_WITH_APP_SPECIFIC_PASSWORD"
# APPLE_TEAM_ID="REPLACE_WITH_APPLE_TEAM_ID"
