{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Headroom",
  "version": "0.4.2",
  "identifier": "com.extraheadroom.headroom",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Headroom",
        "width": 760,
        "height": 560,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "decorations": false,
        "center": true,
        "transparent": true,
        "windowEffects": {
          "effects": [
            "sidebar"
          ],
          "state": "followsWindowActiveState"
        }
      },
      {
        "label": "launcher",
        "title": "Welcome to Headroom",
        "width": 760,
        "height": 540,
        "resizable": false,
        "fullscreen": false,
        "visible": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "decorations": false,
        "center": true,
        "transparent": true,
        "windowEffects": {
          "effects": [
            "sidebar"
          ],
          "state": "followsWindowActiveState"
        }
      }
    ],
    "security": {
      "csp": "default-src 'self'; connect-src 'self' ipc: http://ipc.localhost https://ipc.localhost https://*.clarity.ms; img-src 'self' asset: data: blob: https://*.clarity.ms; style-src 'self' 'unsafe-inline'; font-src 'self' data:; script-src 'self' 'wasm-unsafe-eval' https://*.clarity.ms"
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": [
          "headroom"
        ]
      }
    },
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3QkUyNEU0MjVBMkRDM0MKUldRODNLSWw1Q1MrbC93MitlYTVoUXViSXJQNGVQWDdBRXA0Qkl4WGtpSEttNm5YTDB3QWtncEoK",
      "endpoints": []
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ],
    "macOS": {
      "minimumSystemVersion": "14.0",
      "infoPlist": "Info.plist",
      "entitlements": "Entitlements.plist"
    }
  }
}
