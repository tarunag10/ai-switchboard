# Remote-services operator/fork build. Do not use this file for the default
# local-free public build.
HEADROOM_BUILD_FLAVOR="remote-services"
VITE_HEADROOM_BUILD_FLAVOR="remote-services"
HEADROOM_LOCAL_ONLY="0"
VITE_HEADROOM_LOCAL_ONLY="0"
HEADROOM_REMOTE_SERVICES="1"
VITE_HEADROOM_REMOTE_SERVICES="1"
VITE_HEADROOM_REMOTE_TELEMETRY="1"

# Desktop app runtime
HEADROOM_ACCOUNT_API_BASE_URL="https://your-account-api.example.com/api/v1"
HEADROOM_APTABASE_APP_KEY="REPLACE_WITH_APTABASE_APP_KEY"
HEADROOM_SENTRY_DSN="REPLACE_WITH_SENTRY_DSN"
VITE_SENTRY_DSN="REPLACE_WITH_SENTRY_DSN"
VITE_CLARITY_PROJECT_ID="REPLACE_WITH_CLARITY_PROJECT_ID"
VITE_HEADROOM_SALES_CONTACT_URL="mailto:hello@example.com"
VITE_HEADROOM_CONTACT_FORM_URL="https://your-support.example.com/contact_request"
